{
  "name": "silkroad",
  "version": "0.1.0",
  "description": "A lightweight macOS EPUB reader with notes, translation, and AI reading tools.",
  "license": "GPL-3.0-only",
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5173 && npm run build:main && npm run rebuild:native && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 ./node_modules/.bin/electron .",
    "build": "npm run typecheck && vite build && npm run build:main",
    "build:main": "node scripts/clean-main-dist.mjs && tsc -p tsconfig.main.json && node scripts/build-apple-translate-helper.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json",
    "test": "vitest run --config vitest.config.ts",
    "icons": "node scripts/generate-icons.mjs",
    "rebuild:native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "start": "npm run build && npm run rebuild:native && electron .",
    "dist": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@xmldom/xmldom": "0.9.10",
    "better-sqlite3": "latest",
    "electron-squirrel-startup": "^1.0.1",
    "epubjs": "^0.3.93",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "latest",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "overrides": {
    "@xmldom/xmldom": "0.9.10"
  },
  "build": {
    "appId": "dev.silkroad.reader",
    "productName": "SilkRoad",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
